  "story": {
    "name": "YiWeb-自主测试 · 故事任务",
    "description": "全量/增量/一致性三层自检体系：规则引擎驱动，文档基线对比代码实际",
    "scenarios": [
      {
        "name": "场景1-全量自检",
        "description": "扫描项目根目录 → 检查项目说明(完整项目画像?) → 检查项目说明书(≥3个领域术语?) → 检查故事目录(每个任务都有完整文档?) → 检查架构规则(模块间有违规引用?) → 检查安全(代码中藏有密码或密钥?) → 检查版本(各处版本号一致?) → 检查分支(分支名规范?) → 全部通过生成健康报告",
        "sourceFiles": [
          {
            "type": "source",
            "file": "自检脚本",
            "keyContent": "检查项注册表 (JSON)",
            "description": "15 项规则配置"
          },
          {
            "type": "source",
            "file": "自检脚本",
            "keyContent": "执行引擎",
            "description": "顺序/并行/降级"
          },
          {
            "type": "source",
            "file": "自检脚本",
            "keyContent": "报告生成器",
            "description": "JSON + 终端"
          },
          {
            "type": "source",
            "file": "CLAUDE.md",
            "keyContent": "五大标记段",
            "description": "claude-completeness 检查依据"
          },
          {
            "type": "test",
            "file": "tests/self-test/full.test.js",
            "keyContent": "全量自检测试",
            "description": "验证合规+违规场景"
          }
        ],
        "wireframe": "全量自检流程:\n\n  ┌──────────────────────────────────────────────────────────┐\n  │                    全量自检引擎                          │\n  ├──────────────────────────────────────────────────────────┤\n  │  输入: 项目根目录                                        │\n  │  输出: 健康报告 (JSON + 终端)                            │\n  ├──────────────────────────────────────────────────────────┤\n  │                                                          │\n  │  ① 扫描根目录  →  ② 加载15项规则  →  ③ 顺序/并行执行    │\n  │       │                  │                    │          │\n  │       ▼                  ▼                    ▼          │\n  │  ┌─────────┐      ┌───────────┐        ┌───────────┐    │\n  │  │检查项目 │      │claude-    │        │architecture│    │\n  │  │说明     │      │completenes│        │-rules      │    │\n  │  │(5字段)  │      │s (标记段) │        │(分层约束)  │    │\n  │  └─────────┘      └───────────┘        └───────────┘    │\n  │                                                          │\n  │  ┌─────────┐      ┌───────────┐        ┌───────────┐    │\n  │  │检查故事 │      │security-  │        │version-    │    │\n  │  │目录     │      │scan       │        │consistency │    │\n  │  │(文档完整)│      │(密钥检测) │        │(版本一致)  │    │\n  │  └─────────┘      └───────────┘        └───────────┘    │\n  │                                                          │\n  │  ┌─────────┐      ┌───────────┐        ┌───────────┐    │\n  │  │branch-  │      │doc-format │        │code-style  │    │\n  │  │naming   │      │(引用完整) │        │(风格一致)  │    │\n  │  │(feat/*) │      └───────────┘        └───────────┘    │\n  │  └─────────┘                                             │\n  │                                                          │\n  │  ④ 汇总结果 → ⑤ 生成健康度报告 (全部通过/部分失败)       │\n  └──────────────────────────────────────────────────────────┘",
